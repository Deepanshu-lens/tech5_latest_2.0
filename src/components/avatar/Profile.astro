---
import { actions } from "astro:actions";
import NavbarProfileManager from "@/managers/navbar-profile.svelte";
// import pb from "@/lib/sharedPB";

const { data, error } = await Astro.callAction(actions.user.avatar, []);
const { isVertical } = Astro.props;
const MAX_NAME_LENGTH = 20;
const MAX_EMAIL_LENGTH = 30;
let displayName =
  data?.user.name || `${data?.user.firstName} ${data?.user.lastName || ""}`;
let displayEmail = data?.user.email;

// Trim the display name to ensure it doesn't exceed MAX_NAME_LENGTH
if (displayName.length > MAX_NAME_LENGTH) {
  displayName = displayName.slice(0, MAX_NAME_LENGTH - 3) + "...";
}

if (data?.user.email.length > MAX_EMAIL_LENGTH) {
  displayEmail = data?.user.email.slice(0, MAX_EMAIL_LENGTH - 3) + "...";
}
---

<NavbarProfileManager client:only="svelte" {displayName} {displayEmail} {isVertical} {data}/>
